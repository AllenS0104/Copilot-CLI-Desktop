{
  "name": "copilot-desktop",
  "version": "0.1.0",
  "description": "Desktop UI wrapper for GitHub Copilot CLI",
  "author": {
    "name": "Copilot Desktop Team",
    "email": "copilot-desktop@github.com"
  },
  "homepage": "https://github.com/features/copilot/cli/",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"cross-env NODE_ENV=development webpack serve --config webpack.config.js\" \"cross-env NODE_ENV=development electron .\"",
    "build": "webpack --mode production && tsc -p tsconfig.main.json",
    "start": "cross-env NODE_ENV=production electron .",
    "pack": "npm run build && electron-builder"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "node-pty": "^1.0.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zustand": "^4.5.0",
    "react-markdown": "^9.0.0",
    "react-syntax-highlighter": "^15.5.0",
    "diff2html": "^3.4.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-syntax-highlighter": "^15.5.0",
    "typescript": "^5.3.0",
    "ts-node": "^10.9.0",
    "ts-loader": "^9.5.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^4.15.0",
    "html-webpack-plugin": "^5.6.0",
    "css-loader": "^6.8.0",
    "style-loader": "^3.3.0",
    "postcss-loader": "^7.3.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.0"
  },
  "build": {
    "appId": "com.github.copilot-desktop",
    "productName": "Copilot Desktop",
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "signAndEditExecutable": false,
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Copilot Desktop",
      "artifactName": "CopilotDesktop-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "CopilotDesktop-Portable-${version}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        },
        {
          "target": "rpm",
          "arch": ["x64"]
        },
        {
          "target": "tar.gz",
          "arch": ["x64"]
        }
      ],
      "category": "Development",
      "icon": "assets/icon.png",
      "artifactName": "CopilotDesktop-${version}-linux-x64.${ext}"
    }
  }
}
